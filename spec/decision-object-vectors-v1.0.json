    {
      "id": "DO-003",
      "category": "basic-matching",
      "description": "REQUEST_HUMAN: tool name in list triggers approval",
      "rules": [
        {
          "id": "SEC-002",
          "name": "dangerous_tool_list",
          "description": "Require approval for dangerous tools",
          "category": "security",
          "triggers": ["exec", "bash"],
          "when": "tool.name in (\"exec\", \"bash\")",
          "then": "REQUEST_HUMAN \"dangerous tool requires approval\"",
          "priority": 10,
          "enabled": true
        }
      ],
      "context": { "tool.name": "exec" },
      "expected": {
        "decision": "REQUEST_HUMAN",
        "matchedRules": [
          { "ruleId": "SEC-002", "decision": "REQUEST_HUMAN", "reason": "dangerous tool requires approval" }
        ],
        "totalEvaluated": 1,
        "totalMatched": 1
      }
    },
    {
      "id": "DO-004",
      "category": "tool-args",
      "description": "DENY: tool arg contains dangerous substring",
      "rules": [
        {
          "id": "SEC-003",
          "name": "block_dangerous_command",
          "description": "Block commands containing 'rm'",
          "category": "security",
          "triggers": ["exec"],
          "when": "tool.args.command contains \"rm\"",
          "then": "DENY \"dangerous command: contains rm\"",
          "priority": 5,
          "enabled": true
        }
      ],
      "context": { "tool.name": "exec", "tool.args": { "command": "rm -rf /" }, "tool.args.command": "rm -rf /" },
      "expected": {
        "decision": "DENY",
        "matchedRules": [
          { "ruleId": "SEC-003", "decision": "DENY", "reason": "dangerous command: contains rm" }
        ],
        "totalEvaluated": 1,
        "totalMatched": 1
      }
    },
    {
      "id": "DO-005",
      "category": "tool-args",
