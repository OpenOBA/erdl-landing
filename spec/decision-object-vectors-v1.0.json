      "context": { "tool.name": "exec", "tool.args": { "command": "ls" }, "tool.args.command": "ls" },
      "expected": {
        "decision": "ALLOW",
        "matchedRules": [
          { "ruleId": "ALLOW_ALL", "decision": "ALLOW", "instruction": "exec allowed with caution" }
