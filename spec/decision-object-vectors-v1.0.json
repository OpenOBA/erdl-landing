    {
      "id": "DO-006",
      "category": "regex",
      "description": "CORRECT: regex match on file path triggers correction",
      "rules": [
        {
          "id": "SEC-004",
          "name": "path_out_of_workspace",
          "description": "Correct path outside workspace",
          "category": "security",
          "triggers": ["write_file"],
          "when": "tool.args.path match \"^/(etc|var|sys)\"",
          "then": "CORRECT \"use workspace path\"",
          "priority": 10,
          "enabled": true
        }
      ],
      "context": { "tool.name": "write_file", "tool.args": { "path": "/etc/config.txt" }, "tool.args.path": "/etc/config.txt" },
      "expected": {
        "decision": "CORRECT",
        "matchedRules": [
          { "ruleId": "SEC-004", "decision": "CORRECT", "correction": "use workspace path" }
        ],
        "totalEvaluated": 1,
        "totalMatched": 1
      }
    },
    {
