  "description": "Cross-implementation test vectors for ERDL Decision Object v1.0. These vectors are designed for enterprise compliance and audit scenarios — covering regulated industries (finance, healthcare, critical infrastructure), multi-agent governance, and tamper-evident audit chains. Any compliant ERDL implementation MUST reproduce these vectors byte-for-byte when given the same rules and context.",
  "vectors": [
    {
      "id": "DO-001",
      "category": "security-baseline",
      "scenario": "A financial services Agent attempts to execute a shell command outside an approved allowlist. The security Guardian blocks it.",
      "rules": [
        {
          "id": "FIN-SEC-001",
          "name": "restrict_exec_to_allowlist",
          "description": "Only commands on the finance operations allowlist may be executed",
          "category": "security",
          "triggers": [
            "exec"
          ],
          "when": "tool.name = \"exec\"",
          "then": "DENY \"exec blocked by financial security policy\"",
          "priority": 5,
          "enabled": true,
          "ring": 0,
          "conditions": [
            {
              "kind": "context_matches",
              "field": "tool.name",
              "operator": "eq",
              "value": "exec"
            }
          ]
        }
      ],
      "context": {
        "tool.name": "exec",
        "tool.args": {
          "command": "sudo systemctl restart nginx"
        },
        "tool.args.command": "sudo systemctl restart nginx"
      },
      "expected": {
        "decision": "DENY",
        "matchedRules": [
          {
            "ruleId": "FIN-SEC-001",
            "decision": "DENY",
            "reason": "exec blocked by financial security policy",
            "ring": 0
          }
        ],
        "totalEvaluated": 1,
        "totalMatched": 1
      }
    },
