{
  "$schema": "https://openoba.com/erdl/decision-object-v1.0/schema.json",
  "spec": "decision-object-v1.0",
  "version": "1.0.0-draft",
  "created": "2026-07-10",
  "maintainer": "OpenOBA (https://openoba.com)",
  "description": "Cross-implementation test vectors for ERDL Decision Object v1.0. Any compliant ERDL implementation MUST reproduce these vectors byte-for-byte when given the same rules and context.",
  "vectors": [
    {
      "id": "DO-001",
      "category": "basic-matching",
      "description": "DENY: tool name exact match blocks execution",
      "rules": [
        {
          "id": "SEC-001",
          "name": "block_exec_tool",
          "description": "Block all exec tool calls",
          "category": "security",
          "triggers": ["exec"],
          "when": "tool.name = \"exec\"",
          "then": "DENY \"exec tool blocked\"",
          "priority": 10,
          "enabled": true
        }
      ],
      "context": { "tool.name": "exec" },
      "expected": {
        "decision": "DENY",
        "matchedRules": [
          { "ruleId": "SEC-001", "decision": "DENY", "reason": "exec tool blocked" }
        ],
        "totalEvaluated": 1,
        "totalMatched": 1
      }
    },
    {
      "id": "DO-002",
      "category": "basic-matching",
      "description": "PASS: rule does not match different tool name",
      "rules": [
