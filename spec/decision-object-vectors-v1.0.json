    {
      "id": "DO-011",
      "category": "override",
      "description": "Override can relax DENY → ALLOW (safe direction)",
      "rules": [
        {
          "id": "BLOCK_ALL_EXEC",
          "name": "block_all_exec",
          "description": "Block all exec tool calls",
          "category": "security",
          "triggers": ["exec"],
          "when": "tool.name = \"exec\"",
          "then": "DENY \"exec blocked by default\"",
          "priority": 10,
          "enabled": true,
          "override": false
        },
        {
          "id": "ALLOW_SAFE_EXEC",
          "name": "allow_safe_exec",
          "description": "Allow safe exec commands via override",
          "category": "security",
          "triggers": ["exec"],
          "when": "tool.args.command contains \"ls\"",
          "then": "ALLOW \"safe exec allowed\"",
          "priority": 50,
          "enabled": true,
          "override": true
        }
      ],
      "context": { "tool.name": "exec", "tool.args": { "command": "ls -la" }, "tool.args.command": "ls -la" },
      "expected": {
        "decision": "ALLOW",
        "matchedRules": [
          { "ruleId": "ALLOW_SAFE_EXEC", "decision": "ALLOW", "instruction": "safe exec allowed" }
        ],
        "totalEvaluated": 2,
        "totalMatched": 2
      }
    },
    {
      "id": "DO-012",
      "category": "override",
      "description": "Override is REJECTED in unsafe direction (ALLOW → DENY)",
      "rules": [
        {
          "id": "ALLOW_ALL",
          "name": "allow_all_tools",
          "description": "Allow all tools by default",
          "category": "engineering",
          "triggers": ["exec"],
          "when": "tool.name = \"exec\"",
          "then": "ALLOW \"allowed\"",
          "priority": 10,
          "enabled": true,
          "override": false
        },
        {
          "id": "BLOCK_OVERRIDE",
          "name": "block_via_override",
          "description": "Attempt to block via override",
          "category": "security",
          "triggers": ["exec"],
          "when": "tool.args.command contains \"rm\"",
          "then": "DENY \"trying to block via override\"",
          "priority": 50,
          "enabled": true,
          "override": true
        }
      ],
      "context": { "tool.name": "exec", "tool.args": { "command": "rm -rf /" }, "tool.args.command": "rm -rf /" },
      "expected": {
        "decision": "ALLOW",
        "matchedRules": [
          { "ruleId": "ALLOW_ALL", "decision": "ALLOW", "instruction": "allowed" }
        ],
        "totalEvaluated": 2,
        "totalMatched": 1
      }
    },
    {
      "id": "DO-013",
      "category": "execution-rings",
      "description": "Ring 0 DENY wins over Ring 3 ALLOW regardless of priority",
      "rules": [
        {
          "id": "ALLOW_RING3",
          "name": "allow_exec_r3",
          "description": "Allow exec in ring 3",
          "category": "engineering",
          "triggers": ["exec"],
          "when": "tool.name = \"exec\"",
          "then": "ALLOW \"ring3 ok\"",
          "priority": 1,
          "enabled": true,
          "ring": 3
        },
        {
          "id": "BLOCK_RING0",
          "name": "block_exec_r0",
          "description": "Block exec in ring 0",
          "category": "security",
          "triggers": ["exec"],
          "when": "tool.name = \"exec\"",
          "then": "DENY \"ring0 blocks all exec\"",
          "priority": 100,
          "enabled": true,
          "ring": 0
        }
      ],
      "context": { "tool.name": "exec" },
      "expected": {
        "decision": "DENY",
        "matchedRules": [
          { "ruleId": "BLOCK_RING0", "decision": "DENY", "reason": "ring0 blocks all exec" }
        ],
        "totalEvaluated": 2,
        "totalMatched": 1
      }
    },
    {
      "id": "DO-014",
      "category": "execution-rings",
      "description": "Ring 0 EMERGENCY_HALT short-circuits all further evaluation",
      "rules": [
        {
          "id": "HALT_RING0",
          "name": "emergency_halt",
          "description": "Emergency halt on matched condition",
          "category": "security",
          "triggers": ["exec"],
          "when": "tool.name = \"exec\"",
          "then": "EMERGENCY_HALT \"halt all\"",
          "priority": 1,
          "enabled": true,
          "ring": 0
        },
        {
          "id": "OVERRIDE_RING3",
          "name": "try_override_halt",
          "description": "Attempt to override halt from ring 3",
          "category": "engineering",
          "triggers": ["exec"],
          "when": "tool.name = \"exec\"",
          "then": "ALLOW \"trying to override\"",
          "priority": 1,
          "enabled": true,
          "override": true,
          "ring": 3
        }
      ],
      "context": { "tool.name": "exec" },
      "expected": {
        "decision": "EMERGENCY_HALT",
        "matchedRules": [
          { "ruleId": "HALT_RING0", "decision": "EMERGENCY_HALT", "reason": "halt all" }
        ],
        "totalEvaluated": 1,
        "totalMatched": 1
      }
    },
